# Inworld API credential (Base64 string from Inworld Portal → API Keys)
# NEVER commit the real value — copy this file to .env and fill it in locally.
INWORLD_API_KEY=

# Port for static site + WebSocket proxy (default 8787, local dev only)
PORT=8787

# --- Vercel only (no Railway needed) ---
# Add INWORLD_API_KEY in Vercel → Settings → Environment Variables → redeploy.
# Voice uses WebRTC directly to Inworld — no VOICE_BACKEND_URL required.

# --- Optional legacy Railway proxy (not needed if using Vercel + INWORLD_API_KEY) ---
# VOICE_BACKEND_URL=https://your-app.up.railway.app
